# Copy this file to .env.local and fill in your values

# Anthropic API key — required for real AI mode
ANTHROPIC_API_KEY=sk-ant-...

# Set to "real" to use Claude AI, omit or set to anything else to use mock data
NEXT_PUBLIC_AI_MODE=real

# Optional: comma-separated origins allowed to call AI routes in production.
# Same-origin requests are allowed automatically.
HUDDY_ALLOWED_ORIGINS=https://huddy-v0-1.vercel.app

# Optional: per-IP in-memory AI route limit per minute.
HUDDY_AI_RATE_LIMIT_PER_MINUTE=24
